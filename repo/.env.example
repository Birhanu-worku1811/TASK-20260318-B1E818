APP_NAME=offline-platform-api
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/offline_platform
ALLOW_DEV_SQLITE_OVERRIDE=false
MASTER_ENCRYPTION_KEY=replace_with_base64_32_byte_key
ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_SECRET=replace_with_strong_secret
JWT_ALGORITHM=HS256
ORDER_AUTO_VOID_MINUTES=30
ACCOUNT_LOCK_MINUTES=15
FAILED_LOGIN_LIMIT=5
ATTACHMENT_MAX_MB=20
RECEIPT_PRINTER_BACKEND=noop
RECEIPT_PRINTER_HOST=127.0.0.1
RECEIPT_PRINTER_PORT=9100
RECEIPT_PRINTER_DEVICE_PATH=/dev/usb/lp0
BOOTSTRAP_MODE=false
INSTALL_BOOTSTRAP_TOKEN=
ALLOW_ADMIN_REVIEWER_PROJECT_OVERRIDE=true
